import tkinter as tk
from tkinter import ttk, messagebox
import json
import os
from datetime import datetime

# Константа для имени файла данных
DATA_FILE = "trainings.json"

class TrainingPlanner:
    def __init__(self, root):
        """Инициализация главного окна и всех компонентов"""
        self.root = root
        self.root.title("Training Planner - План тренировок")
        self.root.geometry("800x600")
        
        # Создание интерфейса
        self.create_input_frame()
        self.create_filter_frame()
        self.create_table_frame()
        self.create_buttons_frame()
        self.create_status_bar()

        # Инициализация данных
        self.trainings = []
        self.filtered_trainings = []
        self.load_data()
        
        # Обновление таблицы
        self.update_table()
    
    def create_input_frame(self):
        """Создание рамки для ввода новой тренировки"""
        input_frame = ttk.LabelFrame(self.root, text="Добавление новой тренировки", padding=10)
        input_frame.pack(fill="x", padx=10, pady=5)
        
        # Поле Дата
        ttk.Label(input_frame, text="Дата (ГГГГ-ММ-ДД):", font=("Arial", 10)).grid(row=0, column=0, padx=5, pady=5, sticky="e")
        self.date_entry = ttk.Entry(input_frame, width=15, font=("Arial", 10))
        self.date_entry.grid(row=0, column=1, padx=5, pady=5)
        self.date_entry.insert(0, datetime.today().strftime("%Y-%m-%d"))
        
        # Поле Тип тренировки
        ttk.Label(input_frame, text="Тип тренировки:", font=("Arial", 10)).grid(row=0, column=2, padx=5, pady=5, sticky="e")
        self.type_entry = ttk.Combobox(input_frame, values=["Бег", "Велосипед", "Плавание", "Силовая", "Йога", "Футбол", "Теннис"], 
                                        width=15, font=("Arial", 10))
        self.type_entry.grid(row=0, column=3, padx=5, pady=5)
        self.type_entry.set("Выберите тип")
        
        # Поле Длительность
        ttk.Label(input_frame, text="Длительность (мин):", font=("Arial", 10)).grid(row=0, column=4, padx=5, pady=5, sticky="e")
        self.duration_entry = ttk.Entry(input_frame, width=10, font=("Arial", 10))
        self.duration_entry.grid(row=0, column=5, padx=5, pady=5)
        
        # Кнопка Добавить
        self.add_btn = ttk.Button(input_frame, text="Добавить тренировку", command=self.add_training)
        self.add_btn.grid(row=0, column=6, padx=10, pady=5)
        
        # Подсказка
        ttk.Label(input_frame, text="* Все поля обязательны для заполнения", font=("Arial", 8), foreground="gray").grid(row=1, column=0, columnspan=7, pady=5)
    
    def create_filter_frame(self):
        """Создание рамки для фильтрации"""
        filter_frame = ttk.LabelFrame(self.root, text="Фильтрация тренировок", padding=10)
        filter_frame.pack(fill="x", padx=10, pady=5)
        
        # Фильтр по типу
        ttk.Label(filter_frame, text="Фильтр по типу:", font=("Arial", 10)).grid(row=0, column=0, padx=5, pady=5, sticky="e")
        self.type_filter = ttk.Combobox(filter_frame, values=["Все", "Бег", "Велосипед", "Плавание", "Силовая", "Йога", "Футбол", "Теннис"], 
                                         width=15, font=("Arial", 10))
        self.type_filter.grid(row=0, column=1, padx=5, pady=5)
        self.type_filter.set("Все")
        self.type_filter.bind("<<ComboboxSelected>>", lambda e: self.apply_filters())
        
        # Фильтр по дате
        ttk.Label(filter_frame, text="Фильтр по дате (ГГГГ-ММ-ДД):", font=("Arial", 10)).grid(row=0, column=2, padx=5, pady=5, sticky="e")
        self.date_filter = ttk.Entry(filter_frame, width=15, font=("Arial", 10))
        self.date_filter.grid(row=0, column=3, padx=5, pady=5)
        
        # Кнопки фильтрации
        self.filter_btn = ttk.Button(filter_frame, text="Применить фильтры", command=self.apply_filters)
        self.filter_btn.grid(row=0, column=4, padx=10, pady=5)
        
        self.reset_btn = ttk.Button(filter_frame, text="Сбросить фильтры", command=self.reset_filters)
        self.reset_btn.grid(row=0, column=5, padx=5, pady=5)
        
        # Кнопка обновления таблицы
        self.refresh_btn = ttk.Button(filter_frame, text="Обновить таблицу", command=self.update_table)
        self.refresh_btn.grid(row=0, column=6, padx=5, pady=5)
    
    def create_table_frame(self):
        """Создание таблицы для отображения тренировок"""
        table_frame = ttk.Frame(self.root)
        table_frame.pack(fill="both", expand=True, padx=10, pady=5)
        
        # Настройка стиля таблицы
        style = ttk.Style()
        style.configure("Treeview", font=("Arial", 10))
        style.configure("Treeview.Heading", font=("Arial", 11, "bold"))
        
        # Создание таблицы
        columns = ("date", "type", "duration")
        self.tree = ttk.Treeview(table_frame, columns=columns, show="headings", height=15)
        
        # Настройка заголовков
        self.tree.heading("date", text="Дата", command=lambda: self.sort_by_column("date"))
        self.tree.heading("type", text="Тип тренировки", command=lambda: self.sort_by_column("type"))
        self.tree.heading("duration", text="Длительность (мин)", command=lambda: self.sort_by_column("duration"))
        
        # Настройка ширины колонок
        self.tree.column("date", width=120, anchor="center")
        self.tree.column("type", width=150, anchor="center")
        self.tree.column("duration", width=120, anchor="center")
        
        # Добавление скроллбара
        scrollbar = ttk.Scrollbar(table_frame, orient="vertical", command=self.tree.yview)
        self.tree.configure(yscrollcommand=scrollbar.set)
        
        self.tree.pack(side="left", fill="both", expand=True)
        scrollbar.pack(side="right", fill="y")
    
    def create_buttons_frame(self):
        """Создание рамки с дополнительными кнопками"""
        buttons_frame = ttk.Frame(self.root)
        buttons_frame.pack(fill="x", padx=10, pady=5)
        
        # Кнопка удаления
        self.delete_btn = ttk.Button(buttons_frame, text="🗑 Удалить выбранную тренировку", command=self.delete_training)
        self.delete_btn.pack(side="left", padx=5)
        
        # Кнопка экспорта
        self.export_btn = ttk.Button(buttons_frame, text="💾 Экспорт в JSON", command=self.export_data)
        self.export_btn.pack(side="left", padx=5)
        
        # Кнопка импорта
        self.import_btn = ttk.Button(buttons_frame, text="📂 Импорт из JSON", command=self.import_data)
        self.import_btn.pack(side="left", padx=5)
        
        # Кнопка очистки всех данных
        self.clear_btn = ttk.Button(buttons_frame, text="⚠ Очистить все данные", command=self.clear_all_data)
        self.clear_btn.pack(side="right", padx=5)
        
        # Информация о количестве записей
        self.count_label = ttk.Label(buttons_frame, text="", font=("Arial", 10))
        self.count_label.pack(side="right", padx=10)
    
    def create_status_bar(self):
        """Создание статусной строки"""
        self.status_bar = tk.StringVar()
        self.status_bar.set("Готов к работе")
        self.status_var = ttk.Label(self.root, textvariable=self.status_bar, relief="sunken", anchor="w", font=("Arial", 9))
        self.status_var.pack(fill="x", padx=10, pady=5)
    
    def validate_date(self, date_string):
        """Проверка формата даты"""
        try:
            datetime.strptime(date_string, "%Y-%m-%d")
            return True
        except ValueError:
            return False
    
    def validate_duration(self, duration_string):
        """Проверка корректности длительности"""
        try:
            duration = float(duration_string)
            if duration > 0 and duration <= 1440:  # Максимум 24 часа
                return True, duration
            else:
                return False, None
        except ValueError:
            return False, None
    
    def add_training(self):
        """Добавление новой тренировки с полной валидацией"""
        date = self.date_entry.get().strip()
        training_type = self.type_entry.get().strip()
        duration_str = self.duration_entry.get().strip()
        
        # Проверка заполнения всех полей
        if not date or not training_type or not duration_str:
            messagebox.showerror("Ошибка", "Пожалуйста, заполните все поля")
            self.status_bar.set("Ошибка: не все поля заполнены")
            return
        
        # Проверка выбора типа тренировки
        if training_type == "Выберите тип":
            messagebox.showerror("Ошибка", "Пожалуйста, выберите тип тренировки")
            self.status_bar.set("Ошибка: тип тренировки не выбран")
            return
        
        # Валидация даты
        if not self.validate_date(date):
            messagebox.showerror("Ошибка", "Неверный формат даты!\nИспользуйте формат: ГГГГ-ММ-ДД\nПример: 2024-12-25")
            self.status_bar.set("Ошибка: неверный формат даты")
            return
        
        # Валидация длительности
        is_valid, duration = self.validate_duration(duration_str)
        if not is_valid:
            messagebox.showerror("Ошибка", "Длительность должна быть положительным числом (1-1440 минут)")
            self.status_bar.set("Ошибка: неверная длительность")
            return
        
        # Добавление тренировки
        training = {
            "date": date,
            "type": training_type,
            "duration": duration
        }
        
        self.trainings.append(training)
        self.save_data()
        self.apply_filters()  # Обновляем таблицу с учётом фильтров
        
        # Очистка полей
        self.duration_entry.delete(0, tk.END)
        self.type_entry.set("Выберите тип")
        
        self.status_bar.set(f"✓ Тренировка добавлена: {training_type}, {duration} мин, {date}")
        
        # Визуальная индикация
        self.add_btn.config(state="disabled")
        self.root.after(1000, lambda: self.add_btn.config(state="normal"))
    
    def delete_training(self):
        """Удаление выбранной тренировки"""
        selected = self.tree.selection()
        if not selected:
            messagebox.showwarning("Предупреждение", "Выберите тренировку для удаления")
            self.status_bar.set("Предупреждение: тренировка не выбрана")
            return
        
        # Подтверждение удаления
        if not messagebox.askyesno("Подтверждение", "Вы уверены, что хотите удалить выбранную тренировку?"):
            return
        
        # Получение данных из выбранной строки
        item = selected[0]
        values = self.tree.item(item, "values")
        
        # Поиск и удаление из списка
        for i, training in enumerate(self.trainings):
            if (training["date"] == values[0] and 
                training["type"] == values[1] and 
                str(training["duration"]) == values[2]):
                deleted = self.trainings.pop(i)
                self.save_data()
                self.apply_filters()
                self.status_bar.set(f"✓ Тренировка удалена: {deleted['type']}, {deleted['date']}")
                break
    
    def apply_filters(self):
        """Применение фильтров к данным"""
        type_filter = self.type_filter.get()
        date_filter = self.date_filter.get().strip()
        
        filtered = self.trainings.copy()
        
        # Фильтрация по типу
        if type_filter != "Все":
            filtered = [t for t in filtered if t["type"] == type_filter]# Фильтрация по дате
        if date_filter:
            if self.validate_date(date_filter):
                filtered = [t for t in filtered if t["date"] == date_filter]
            else:
                messagebox.showerror("Ошибка", "Неверный формат даты фильтра!\nИспользуйте: ГГГГ-ММ-ДД")
                return
        
        self.filtered_trainings = filtered
        self.update_table(filtered)
        
        # Обновление информации о количестве
        total_count = len(self.trainings)
        filtered_count = len(filtered)
        self.count_label.config(text=f"Показано: {filtered_count} из {total_count}")
        self.status_bar.set(f"Фильтрация применена: {filtered_count} записей")
    
    def reset_filters(self):
        """Сброс всех фильтров"""
        self.type_filter.set("Все")
        self.date_filter.delete(0, tk.END)
        self.apply_filters()
        self.status_bar.set("Фильтры сброшены")
    
    def sort_by_column(self, column):
        """Сортировка таблицы по колонке"""
        data = self.filtered_trainings if self.filtered_trainings else self.trainings
        
        if column == "date":
            sorted_data = sorted(data, key=lambda x: x["date"])
        elif column == "type":
            sorted_data = sorted(data, key=lambda x: x["type"])
        elif column == "duration":
            sorted_data = sorted(data, key=lambda x: x["duration"])
        else:
            sorted_data = data
        
        self.update_table(sorted_data)
        self.status_bar.set(f"Сортировка по колонке: {column}")
    
    def update_table(self, data=None):
        """Обновление таблицы данными"""
        # Очистка таблицы
        for item in self.tree.get_children():
            self.tree.delete(item)
        
        if data is None:
            data = self.trainings
        
        # Сортировка по дате по умолчанию
        data_sorted = sorted(data, key=lambda x: x["date"], reverse=True)
        
        # Заполнение таблицы
        for training in data_sorted:
            self.tree.insert("", "end", values=(
                training["date"],
                training["type"],
                f"{training['duration']:.1f}" if isinstance(training['duration'], float) else str(training['duration'])
            ))
    
    def export_data(self):
        """Экспорт данных в JSON файл"""
        from tkinter import filedialog
        
        filename = filedialog.asksaveasfilename(
            defaultextension=".json",
            filetypes=[("JSON files", "*.json"), ("All files", "*.*")],
            initialfile="trainings_export.json"
        )
        
        if filename:
            try:
                with open(filename, "w", encoding="utf-8") as f:
                    json.dump(self.trainings, f, ensure_ascii=False, indent=2)
                self.status_bar.set(f"✓ Данные экспортированы в {filename}")
                messagebox.showinfo("Успех", f"Данные успешно экспортированы в файл:\n{filename}")
            except Exception as e:
                messagebox.showerror("Ошибка", f"Не удалось экспортировать данные: {str(e)}")
                self.status_bar.set("Ошибка экспорта")
    
    def import_data(self):
        """Импорт данных из JSON файла"""
        from tkinter import filedialog
        
        filename = filedialog.askopenfilename(
            filetypes=[("JSON files", "*.json"), ("All files", "*.*")]
        )
        
        if filename:
            try:
                with open(filename, "r", encoding="utf-8") as f:
                    imported_data = json.load(f)
                
                # Валидация импортированных данных
                if isinstance(imported_data, list):
                    valid_count = 0
                    for item in imported_data:
                        if all(key in item for key in ["date", "type", "duration"]):
                            if self.validate_date(item["date"]) and self.validate_duration(str(item["duration"]))[0]:
                                self.trainings.append(item)
                                valid_count += 1
                    
                    self.save_data()
                    self.apply_filters()
                    self.status_bar.set(f"✓ Импортировано {valid_count} из {len(imported_data)} записей")
                    messagebox.showinfo("Успех", f"Импортировано {valid_count} тренировок")
                else:
                    messagebox.showerror("Ошибка", "Неверный формат файла")
            except Exception as e:
                messagebox.showerror("Ошибка", f"Не удалось импортировать данные: {str(e)}")
                self.status_bar.set("Ошибка импорта")
    
    def clear_all_data(self):
        """Очистка всех данных"""
        if messagebox.askyesno("Подтверждение", "Вы уверены, что хотите удалить ВСЕ тренировки?\nЭто действие нельзя отменить!"):
            self.trainings = []
            self.save_data()
            self.apply_filters()
            self.status_bar.set("✓ Все данные очищены")
            messagebox.showinfo("Успех", "Все тренировки удалены")
    
    def load_data(self):
        """Загрузка данных из JSON файла"""
        if os.path.exists(DATA_FILE):
            try:
                with open(DATA_FILE, "r", encoding="utf-8") as f:
                    self.trainings = json.load(f)
                self.status_bar.set(f"Загружено {len(self.trainings)} тренировок")
            except (json.JSONDecodeError, IOError) as e:
                self.trainings = []
                self.status_bar.set(f"Ошибка загрузки данных: {str(e)}")
        else:
            self.trainings = []
            self.status_bar.set("Новый файл данных создан")
    
    def save_data(self):
        """Сохранение данных в JSON файл"""
        try:
            with open(DATA_FILE, "w", encoding="utf-8") as f:
                json.dump(self.trainings, f, ensure_ascii=False, indent=2)
        except IOError as e:
            messagebox.showerror("Ошибка", f"Не удалось сохранить данные: {str(e)}")
            self.status_bar.set("Ошибка сохранения")

# Главный блок запуска
if __name__ == "__main__":
    root = tk.Tk()
    app = TrainingPlanner(root)
    root.mainloop()
